
## .gitignore Template
```
# Java
target/
*.class
*.jar
*.war
*.ear
.mvn/
mvnw
mvnw.cmd

# Node
node_modules/
dist/
build/
.npm

# IDEs
.idea/
.vscode/
*.iml
*.swp

# Environment
.env
*.key
# The credential-vault master key (#307). Covered by *.key above; listed explicitly so it's
# obvious this never gets committed. Lives in the config dir (also ignored via /vaier/ below).
vault.key
*.conf
*.pem

# ...but the offline fallback page's nginx config is a committed source file, not runtime state.
!offline/default.conf

# Runtime data (secrets, certs, state)
wireguard/
authelia/
traefik/
/vaier/
/geoip/
/icons/
# oauth2-proxy: templates/ are committed sources; config/ is the rendered alpha + client-secret.
oauth2/config/
# dex: config/ is runtime state — the rendered config.yaml plus the upstream/broker secret files.
dex/config/

# WireGuard
wireguard-config/
wg*.conf

# Docker
docker-compose.override.yml

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Claude Code — keep checked-in agents/skills, ignore local/ephemeral state
.claude/settings.local.json
.claude/scheduled_tasks.lock