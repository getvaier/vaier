
## .gitignore Template
```
# Java
target/
*.class
*.jar
*.war
*.ear
.mvn/
mvnw
mvnw.cmd

# Node
node_modules/
dist/
build/
.npm

# IDEs
.idea/
.vscode/
*.iml
*.swp

# Environment
.env
*.key
*.conf
*.pem

# Runtime data (secrets, certs, state)
wireguard/
authelia/
traefik/
/vaier/
/geoip/

# WireGuard
wireguard-config/
wg*.conf

# Docker
docker-compose.override.yml

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Claude Code — keep checked-in agents/skills, ignore local/ephemeral state
.claude/settings.local.json
.claude/scheduled_tasks.lock